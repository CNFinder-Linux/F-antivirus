# AI杀软 — 自定义规则文件
# 每行一条规则，格式: rule_type:pattern:description
# rule_type: block(阻止) / warn(警告) / monitor(仅记录)
# pattern 为正则表达式 (Python re 语法)

# ═══════════════════════════════════════════════
# 高危系统操作
# ═══════════════════════════════════════════════
block:rm\s+-rf\s+[/~]:检测递归删除根目录或家目录
block:dd\s+if=/dev/zero:检测磁盘清零操作
block:mkfs\..*[/dev]:检测格式化硬盘
warn:>=\s*/etc/:写入系统配置目录
warn:chmod\s+777:文件权限过宽

# ═══════════════════════════════════════════════
# 网络连接
# ═══════════════════════════════════════════════
block:(wget|curl)\s+.*\|.*(bash|sh):检测下载并执行
warn:nc\s+-[a-z]*e:检测绑定 shell
warn:iptables\s+-F:清除防火墙规则

# ═══════════════════════════════════════════════
# 持久化 / 后门
# ═══════════════════════════════════════════════
warn:crontab\s+-e:编辑定时任务
warn:@reboot:添加开机自启动
warn:systemctl\s+enable\s+:启用系统服务
block:echo\s+".*"\s*>>?\s*/\.ssh/authorized_keys:添加 SSH 公钥

# ═══════════════════════════════════════════════
# 免杀规避
# ═══════════════════════════════════════════════
block:base64\s+-d.*\|.*(bash|sh):解码后执行
warn:python\s+-c\s+['\"]:内联 Python 执行
warn:perl\s+-e\s+['\"]:内联 Perl 执行

# ═══════════════════════════════════════════════
# 进程 / 内存操作
# ═══════════════════════════════════════════════
block:gdb\s+-p\s+:附加到进程
warn:ptrace:进程跟踪操作
warn:LD_PRELOAD:库注入
